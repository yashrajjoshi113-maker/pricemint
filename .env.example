# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file — it's already in .gitignore.
#
# These are only used by the legacy server.js (not the live site).
# The live static site's Supabase URL/anon key live directly in
# js/auth.js by design — Supabase anon keys are meant to be public,
# real security comes from the Row Level Security policies in
# supabase-schema.sql, not from hiding this key.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key-here
PORT=3000
